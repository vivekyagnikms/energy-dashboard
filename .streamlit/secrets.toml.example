# Copy this file to .streamlit/secrets.toml and fill in your keys.
# .streamlit/secrets.toml is gitignored; this .example file is committed.

# Free at https://www.eia.gov/opendata/register.php
EIA_API_KEY = "your-eia-key-here"

# Free at https://aistudio.google.com/apikey
GEMINI_API_KEY = "your-gemini-key-here"

# Set to true to bypass live Gemini calls (uses canned mock responses).
MOCK_AI = false
